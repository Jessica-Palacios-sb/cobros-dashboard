# ============================================================
#  BASE DE DATOS (Neon Postgres — usuarios y sesiones)
# ============================================================
# Conéctate en console.neon.tech, crea un proyecto y copia la connection string
DATABASE_URL=

# ============================================================
#  AUTENTICACIÓN (Auth.js / NextAuth v5)
# ============================================================
# Genera un secreto con: openssl rand -base64 32
AUTH_SECRET=

# URL del despliegue (en local: http://localhost:3000)
# En Vercel se setea automáticamente, pero puedes forzarla.
AUTH_URL=http://localhost:3000

# --- Proveedor: Google Workspace (recomendado para empresa) ---
# Crea las credenciales en https://console.cloud.google.com/apis/credentials
# Tipo: "ID de cliente de OAuth 2.0" -> Aplicación web
# Origen autorizado:   https://tu-dominio.vercel.app
# URI de redirección:  https://tu-dominio.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Restringe el login a tu dominio corporativo (ej: empresa.com)
# Deja vacío para permitir cualquier cuenta de Google.
ALLOWED_EMAIL_DOMAIN=

# ============================================================
#  REDSHIFT (vía Redshift Data API)
# ============================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Si usas Redshift PROVISIONADO (cluster):
REDSHIFT_CLUSTER_ID=
REDSHIFT_DB=cobros
REDSHIFT_USER=admin

# Si usas Redshift SERVERLESS, comenta lo de arriba y usa:
# REDSHIFT_WORKGROUP=tu-workgroup
# REDSHIFT_DB=cobros

# Nombre de la tabla/vista del histórico de cobros
REDSHIFT_TABLE=cobros

# ============================================================
#  SALESFORCE
# ============================================================
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# Nombre del objeto de Salesforce para casos de cobro
SF_OBJECT=Caso_Cobro__c

# ============================================================
#  NEGOCIO
# ============================================================
# Zona horaria para el corte de "hoy" (NO cambiar salvo otra operación)
BUSINESS_TIMEZONE=America/Bogota
